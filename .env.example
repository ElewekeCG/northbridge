# .env.example
# Copy to .env and fill in real values. .env is gitignored — never commit it.
# In production these values are injected by GitHub Actions from GitHub Secrets,
# written to .env on the EC2 instance just before docker compose up runs.

POSTGRES_PASSWORD=change-this-strong-password
REDIS_PASSWORD=change-this-strong-password
JWT_SECRET=change-this-to-a-long-random-string
AUTH_SECRET_KEY=changeme32charsecretkeyhere
STRIPE_SECRET_KEY=sktest
# htpasswd-style string for the Traefik dashboard and Prometheus basic auth
# Generate with: htpasswd -nb admin yourpassword
# Note: $ characters must be escaped as $$ when used inside docker-compose.yml labels —
# the value here in .env does NOT need escaping, only the labels do.
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$ruca84Hq$mbjdMZBAG.KWn7vfN/SNK/

GRAFANA_ADMIN_PASSWORD=change-this-strong-password

# Slack webhook for Alertmanager notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/THIS/VALUE

# S3 bucket for off-box database backups
BACKUP_S3_BUCKET=northbridge-db-backups
AWS_REGION=eu-west-2
